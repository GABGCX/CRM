# ─── Supabase ─────────────────────────────────────────────
# Painel Supabase → Settings → API
SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
SUPABASE_KEY=sua_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# ─── App ──────────────────────────────────────────────────
NUXT_PUBLIC_APP_DOMAIN=crm.io
NUXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Geracao de tipos do banco (npm run db:types) ─────────
# Connection string (modo URI) em: Settings → Database → Connection string.
# Senha com caracteres especiais deve ser URL-encoded. Nao commitar com a senha real.
SUPABASE_DB_URL=postgresql://postgres:SENHA@db.SEU_PROJECT_ID.supabase.co:5432/postgres
